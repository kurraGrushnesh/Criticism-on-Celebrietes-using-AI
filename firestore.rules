rules_version = '2';

// Firestore Security Rules for Celeb-Sentiment-Tracker
//
// Since all API calls are made directly from the Flutter client
// (no Cloud Functions), the client writes cached celebrity data.
// Rules ensure:
//   1. Only authenticated users (anonymous or signed-in) can read/write.
//   2. Users can only access their own search history.
//   3. Celebrity data is readable by all authenticated users but
//      writable only with valid structure.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Celebrity Profiles ────────────────────────────────────────
    // Any authenticated user can read celebrity data.
    // Writes are allowed for authenticated users (the client caches
    // fresh API responses here).
    match /celebrities/{slug} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.keys().hasAll(['name', 'fetchedAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;

      // Media items sub-collection
      match /media_items/{itemId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && request.resource.data.keys().hasAll(['type', 'title', 'url'])
          && request.resource.data.type in ['news', 'youtube', 'instagram'];
      }

      // Sentiment snapshots sub-collection
      match /sentiment_snapshots/{date} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && request.resource.data.keys().hasAll([
               'positiveCount', 'negativeCount', 'neutralCount',
               'totalMentions', 'dominantEmotion', 'timestamp'
             ]);
      }
    }

    // ── Search History ────────────────────────────────────────────
    // Users can only read/write their own search history document.
    match /search_history/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── Deny everything else by default ─────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
